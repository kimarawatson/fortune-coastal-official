# =============================================================================
# Fortune Coastal Group — environment variables for self-hosted deployment
# =============================================================================
# Copy to `.env` for local dev, and set these on Cloudflare (Workers/Pages)
# as environment variables / secrets for production.
#
# CLIENT-VISIBLE (bundled into the browser build — publishable keys only):
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...your-anon-or-publishable-key..."
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# SERVER-ONLY (never shipped to the browser; read via process.env inside
# TanStack server functions running on Cloudflare Workers):
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi...same-anon-key..."
# Service role key — bypasses RLS. Required for the admin console.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...your-service-role-key..."

# --- Admin console (password-gated, no Supabase user needed) ----------------
# The single password that unlocks /admin. Rotate anytime by changing this
# secret in Cloudflare and redeploying.
ADMIN_PASSWORD="pick-a-long-strong-password"
# Encrypts the admin session cookie. Must be at least 32 random chars.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET="paste-32-plus-random-chars-here"
